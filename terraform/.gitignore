# Local .terraform directories
**/.terraform/*

# NOTE: Terraform state is intentionally committed to this repo (GitHub-only state).
# WARNING: state may contain sensitive values in plaintext.

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files that may contain secrets
*.tfvars
*.tfvars.json
!example.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration and plan files
.terraformrc
terraform.rc
*.tfplan

# Lock file is safe to commit; keep it
!.terraform.lock.hcl
