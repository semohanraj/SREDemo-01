# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files that may contain secrets
*.tfvars
*.tfvars.json
!example.tfvars

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration and plan files
.terraformrc
terraform.rc
*.tfplan

# Lock file is safe to commit; keep it
!.terraform.lock.hcl
